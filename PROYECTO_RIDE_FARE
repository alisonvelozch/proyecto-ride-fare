        "def classify_weather(row):\n",
        "    if pd.isna(row['temp']):\n",
        "        return 'Desconocido'\n",
        "    if row['rain'] > 0.1:\n",
        "        return 'Lluvioso'\n",
        "    elif row['clouds'] > 0.7:\n",
        "        return 'Nublado'\n",
        "    elif row['temp'] < 35: # bajo cero o muy frío\n",
        "        return 'Muy frío'\n",
        "    elif 35 <= row['temp'] < 45:\n",
        "        return 'Frío'\n",
        "    elif 45 <= row['temp'] < 65:\n",
        "        return 'Templado'\n",
        "    else:\n",
        "        return 'Cálido'\n",
        "\n",
        "merged_with_price['weather_condition'] = merged_with_price.apply(classify_weather, axis=1)"
