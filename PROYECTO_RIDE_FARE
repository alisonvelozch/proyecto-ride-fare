        "def classify_vehicle(name):\n",
        "    name = str(name).lower()\n",
        "    if any(k in name for k in ['pool', 'uberx', 'lyft', 'shared']):\n",
        "        return 'Económico'\n",
        "    elif any(k in name for k in ['black', 'lux', 'xl']):\n",
        "        return 'Premium'\n",
        "    elif 'wav' in name:\n",
        "        return 'Accesible'\n",
        "    else:\n",
        "        return 'Otro'\n",
        "\n",
        "merged_with_price['cab_category'] = merged_with_price['name'].apply(classify_vehicle)\n"
